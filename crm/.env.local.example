# =============================================================================
# Variables d'environnement — CRM Next.js
# Copie ce fichier en .env.local et renseigne les valeurs.
# Ne jamais committer .env.local
# =============================================================================

# Base de données SQLite (chemin relatif depuis crm/)
DATABASE_URL="file:./prisma/dev.db"

# Secret de session JWT — chaîne aléatoire longue (min 32 caractères)
# Génère-en une avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRM_SESSION_SECRET=change_me_with_a_long_random_string

# Hash bcrypt du mot de passe admin du CRM
# Génère-le avec : node -e "const b=require('bcryptjs');b.hash('TON_MDP',10).then(console.log)"
CRM_PASSWORD_HASH=
