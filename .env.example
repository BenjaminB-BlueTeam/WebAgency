# =============================================================================
# Variables d'environnement — prospect.js (pipeline de prospection)
# Copie ce fichier en .env et renseigne tes clés.
# Ne jamais committer .env
# =============================================================================

# Anthropic — obligatoire pour la génération IA
ANTHROPIC_API_KEY=sk-ant-...

# Netlify — déploiement automatique des maquettes
NETLIFY_TOKEN=

# Google Places API — recherche de prospects locaux
GOOGLE_PLACES_KEY=

# Firecrawl — scraping des sites existants
FIRECRAWL_KEY=
